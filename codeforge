#!/usr/bin/env python3
import os
import shutil
import tomllib
import argparse
import sys
try:
    import ollama
    from pydantic import BaseModel, Field
    from typing import List
    import json
    from git import Repo
except ImportError as e:
    print(f"Missing dependency: {e}. Please install requirements: pip install ollama gitpython")
    sys.exit(1)

template = """
You are an expertreadme generator and code documentor.
Your goal is to write efficient and easy to understand documentation in the form of a readme for a github.
Never speak in first person. Always use formal yet brief language. Always respond in markdown fromat.
Any code quotes should be placed in backquotes: e.g. `code quote`
Code snippets should be placed in a code block:
e.g.
```
markdown
code block
```
Only include relevant information, and documentation should be simple and concise.

Please write a markdown document for the following repository files:
```
"""

def AutoDoc(link, output_path):
    # Dynamic Defaults
    model = "gemma4:e2b"
    model_context = 32768
    api = "http://127.0.0.1:11434"
    
    cache_dir = os.path.expanduser("~/.cache/codeforge")
    github_repo = link if link else "https://github.com/Perceptronic-Systems/CodeForge"
    src_dir = os.path.join(cache_dir, "source") 
    doc_dir = output_path if output_path else os.path.expanduser("~/generated_doc.md")

    config_path = os.path.expanduser("~/.config/codeforge/config.toml")
    if os.path.exists(config_path):
        with open(config_path, 'rb') as f:
            config = tomllib.load(f)
        try:
            api = config['ollama'].get('host_address', api)
            model_context = config['ollama'].get('model_context', model_context)
            model = config['ollama'].get('model', model)
            if not args.repo:
                github_repo = config['repository'].get('link', github_repo)
            if not args.repo: 
                src_dir = os.path.expanduser(config['repository'].get('repo_dir', src_dir))
            if not args.output:
                doc_dir = os.path.expanduser(config['output'].get('output_dir', doc_dir))
        except Exception as e:
            print("Warning: Could not parse all attributes from config file.")
            print(e)

    if not github_repo:
        print("Error: No repository specified via arguments or config.")
        sys.exit(1)

    ignore = ['.gitignore', '.git', 'LICENSE', 'package.json', 'package-lock.json', 'vite-config.json', '__pycache__', 'node_modules']
    accepted_types = ['.txt', '.pdf', '.cpp', '.py', '.js', '.html', '.css', '.md', '.json', '.toml', '.yml', '.yaml', '.xml', '.sh', '.cs', '.cc', '.cxx', '.hpp', '.h', '.ts', '.tsx', '.go', '.php', '.rb']

    os.makedirs(os.path.dirname(src_dir), exist_ok=True)
    if os.path.exists(src_dir):
        shutil.rmtree(src_dir)
    
    print(f"Cloning {github_repo} into {src_dir}...")
    try:
        Repo.clone_from(github_repo, src_dir)
    except Exception as e:
        print(f"Error cloning repository: {e}")
        sys.exit(1)
     
    print(f"Ollama API: {api}")
    client = ollama.Client(host=api)

    files = []

    def get_files(directory):
        for file in os.listdir(directory):
            proceed = True
            path = os.path.join(directory, file)
            if (not file.startswith('.') and '.' in file):
                if not ('.' + file.split('.')[-1]) in accepted_types:
                    proceed = False
            if file.startswith('.git') or file in ignore:
                proceed = False
            if proceed:
                if os.path.isdir(path):
                    get_files(path)
                elif os.path.isfile(path) and file not in ignore:
                    try:
                        with open(path, 'r', encoding='utf-8') as f:
                            text = f.read()
                        files.append(file + '\n' + text)
                    except Exception:
                        print(f"Error while decoding utf-8 in file '{file}'")

    get_files(src_dir)
    content = '\n```\n\n```\n'.join(files)

    prompt = template + content + "```"
    print(f"Rough estimated token count: {len(prompt) // 4}")

    try:
        stream = client.generate(model=model,
                                 prompt=prompt,
                                 stream=True,
                                 options={
                                     'num_ctx': model_context,
                                     'show_think': False 
                                 })

        print("        Generated: \n")
        generated = ""
        for chunk in stream:
            token = chunk['response']
            print(token, end='', flush=True)
            generated += token

        output_parent = os.path.dirname(os.path.abspath(doc_dir))
        os.makedirs(output_parent, exist_ok=True)

        with open(doc_dir, 'w', encoding='utf-8') as f:
            f.write(generated)
        print(f"\n\n        Done! Documentation saved to {doc_dir}")

    except Exception as e:
        print(f"\nAn error occurred during generation: {e}")


def Subdivide(path, output_path):
    class FileItem(BaseModel):
        name: str = Field(description="The name of the file, including extension if applicable.")
        body: str = Field(description="The full code content of the file.")

    class FileExport(BaseModel):
        files: List[FileItem]

    model = "gemma4:e2b"
    model_context = 32768
    api = "http://127.0.0.1:11434"
    
    cache_dir = os.path.expanduser("~/.cache/codeforge")
    src_dir = os.path.join(cache_dir, "source") 
    doc_dir = output_path if output_path else os.path.expanduser("~/subdivided_code")

    config_path = os.path.expanduser("~/.config/codeforge/config.toml")
    if os.path.exists(config_path):
        with open(config_path, 'rb') as f:
            config = tomllib.load(f)
        try:
            api = config['ollama'].get('host_address', api)
            model_context = config['ollama'].get('model_context', model_context)
            model = config['ollama'].get('model', model)
        except Exception as e:
            print("Warning: Could not parse all attributes from config file.")
            print(e)


    print(f"Ollama API: {api}")
    client = ollama.Client(host=api)

    if not os.path.exists(path):
        print(f"Error: Input path '{path}' does not exist.")
        sys.exit(1)

    try:
        with open(path, 'r', encoding='utf-8') as f:
            source_code_content = f.read()
    except Exception as e:
        print(f"Error reading input file '{path}': {e}")
        sys.exit(1)

    prompt = (
        "You are an expert software architect. Your task is to take the provided monolithic "
        "source code file and subdivide it into a logical, modular structure of multiple files.\n"
        "Analyze the code, split classes, functions, or modules into separate files, and preserve "
        "all logic intact. Ensure proper import statements are added so the files can work together.\n\n"
        "Here is the source code to subdivide:\n"
        f"```\n{source_code_content}\n```"
    )

    try:
        stream = client.chat(
            model=model,
            messages=[
                {
                    'role': 'user',
                    'content': prompt
                }
            ],
            stream=True,
            format=FileExport.model_json_schema(),
            options={
                'temperature': 0,
                'num_ctx': model_context
            }
        )
        
        full_response_text = ""
        print("        Generating Subdivided Code: \n")
        
        for chunk in stream:
            token = chunk['message']['content']
            print(token, end="", flush=True)
            full_response_text += token

        print("\n\nParsing structured JSON and writing files...")
        parsed_data = json.loads(full_response_text)
        file_list = parsed_data.get('files', [])
        
        for file in file_list:
            file_name = file.get('name')
            file_body = file.get('body')

            if not file_name:
                continue

            final_file_path = os.path.normpath(os.path.join(doc_dir, file_name))
            file_dir = os.path.dirname(final_file_path)
            
            if file_dir and not os.path.exists(file_dir):
                os.makedirs(file_dir, exist_ok=True)
                print(f"📁 Created directory: {file_dir}")

            with open(final_file_path, 'w', encoding='utf-8') as f:
                f.write(file_body)
                
            print(f"💾 Written: {final_file_path}")
            
    except Exception as e:
        print(f"\nAn error occurred during generation: {e}")



def main():
    parser = argparse.ArgumentParser(
        description="CodeForge: Intelligent code manipulation using LLMs."
    )

    subparsers = parser.add_subparsers(dest="command", required=True, help="Sub-commands")

    # AUTODOC
    autodoc_parser = subparsers.add_parser("autodoc", help="Generate readme documentation for a github repository.")
    autodoc_parser.add_argument("repo", nargs="?", default="https://github.com/Perceptronic-Systems/CodeForge", 
                                help="The GitHub repository URL to clone.")
    autodoc_parser.add_argument("output", nargs="?", default=os.path.expanduser("~/generated_doc.md"), 
                                help="The output path for the generated markdown file.")

    # SECONDARY
    subdivie_parser = subparsers.add_parser("subdivide", help="Execute secondary tool logic.")
    subdivie_parser.add_argument("path", help="The input file or directory path.")
    subdivie_parser.add_argument("output_path", help="The output path target.")

    args = parser.parse_args()

    # ROUTING
    if args.command == "autodoc":
        AutoDoc(args.repo, args.output)
    elif args.command == "subdivide":
        Subdivide(args.path, args.output_path)

    

if __name__ == "__main__":
    main()